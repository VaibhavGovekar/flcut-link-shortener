// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  // We removed the url line from here because Prisma 7 handles it via config files!
}

generator client {
  provider = "prisma-client-js"
}

model Link {
  id                     String   @id @default(uuid())
  longUrl                String
  shortCode              String   @unique
  createdAt              DateTime @default(now())
  loopTraceMarkerVisible String?  @default("active")
}